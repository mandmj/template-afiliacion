# Amazon Product Advertising API 5.0 - credenciales
# Solicitar alta en https://affiliate-program.amazon.es/ y activar PA-API tras 3 ventas cualificadas
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG={{AMAZON_TAG}}
AMAZON_MARKETPLACE=www.amazon.es

# Awin Publisher ID (no es secreto, se usa para generar deep-links afiliados)
AWIN_PUBLISHER_ID={{AWIN_PUBLISHER_ID}}

# Analítica (opcional)
PUBLIC_GA_ID=
PUBLIC_PLAUSIBLE_DOMAIN=

# Deploy
PUBLIC_SITE_URL=https://{{DOMAIN}}
