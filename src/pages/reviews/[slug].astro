---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/content/Breadcrumb.astro';
import RelatedReviews from '~/components/content/RelatedReviews.astro';
import MiniCompareTable from '~/components/content/MiniCompareTable.astro';
import StickyAmazonCTA from '~/components/afiliados/StickyAmazonCTA.astro';

export const prerender = true;

export async function getStaticPaths() {
  const reviews = await getCollection('reviews');
  return reviews.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const metadata = {
  title: entry.data.metadata?.title || entry.data.title,
  description: entry.data.metadata?.description || entry.data.excerpt,
  canonical: `/reviews/${entry.id}`,
  openGraph: {
    type: 'article',
    images: entry.data.product.image
      ? [{ url: entry.data.product.image, width: 1200, height: 628 }]
      : entry.data.image
        ? [{ url: entry.data.image, width: 1200, height: 628 }]
        : undefined,
  },
};

const canonicalUrl = new URL(`/reviews/${entry.id}`, Astro.site ?? 'https://{{DOMAIN}}').toString();

const reviewJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Review',
  name: entry.data.title,
  url: canonicalUrl,
  datePublished: entry.data.publishDate.toISOString(),
  ...(entry.data.updateDate ? { dateModified: entry.data.updateDate.toISOString() } : {}),
  author: {
    '@type': 'Organization',
    name: '{{SITE_NAME}}',
    url: 'https://{{DOMAIN}}',
  },
  publisher: {
    '@type': 'Organization',
    name: '{{SITE_NAME}}',
    logo: { '@type': 'ImageObject', url: 'https://{{DOMAIN}}/favicon.svg' },
  },
  itemReviewed: {
    '@type': 'Product',
    name: entry.data.product.title,
    image: entry.data.product.image,
    brand: { '@type': 'Brand', name: entry.data.product.brand },
    ...(entry.data.product.rating && entry.data.product.reviewsCount
      ? {
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: entry.data.product.rating,
            reviewCount: entry.data.product.reviewsCount,
            bestRating: 5,
          },
        }
      : {}),
    offers: {
      '@type': 'Offer',
      price: entry.data.product.price,
      priceCurrency: entry.data.product.currency || 'EUR',
      url: entry.data.product.url,
      availability: 'https://schema.org/InStock',
      priceValidUntil: new Date(new Date().setMonth(new Date().getMonth() + 3)).toISOString().split('T')[0],
    },
  },
  reviewRating: { '@type': 'Rating', ratingValue: entry.data.rating, bestRating: 10, worstRating: 0 },
  reviewBody: entry.data.verdict,
  positiveNotes: { '@type': 'ItemList', itemListElement: entry.data.pros.map((p, i) => ({ '@type': 'ListItem', position: i + 1, name: p })) },
  negativeNotes: { '@type': 'ItemList', itemListElement: entry.data.cons.map((c, i) => ({ '@type': 'ListItem', position: i + 1, name: c })) },
};
---

<Layout metadata={metadata}>
  <article class="mx-auto max-w-3xl px-4 py-12 prose dark:prose-invert prose-lime">
    <Breadcrumb
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Reviews', href: '/reviews' },
        { label: entry.data.product.title },
      ]}
    />

    <header class="not-prose mb-8">
      <p class="text-sm uppercase tracking-wider text-lime-600 dark:text-lime-400 font-semibold">
        {entry.data.category}
      </p>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mt-2 leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400">{entry.data.excerpt}</p>
      <div class="mt-4 text-sm text-slate-500">
        Por {entry.data.author} ·{' '}
        <time datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    <Content />

    <MiniCompareTable currentSlug={entry.id} limit={5} />
    <RelatedReviews currentSlug={entry.id} tags={entry.data.tags} />
  </article>

  <StickyAmazonCTA
    url={entry.data.product.url}
    asin={entry.data.product.asin}
    title={entry.data.product.title}
    price={entry.data.product.price}
    currency={entry.data.product.currency}
  />

  <script type="application/ld+json" set:html={JSON.stringify(reviewJsonLd)} is:inline />
</Layout>
