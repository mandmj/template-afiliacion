---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/content/Breadcrumb.astro';

const metadata = {
  title: 'Comparativas de {{PRODUCTO_PLURAL}}',
  description:
    'Comparamos los {{PRODUCTO_PLURAL}} más vendidos en Amazon España cara a cara, con tablas claras y veredicto por perfil de usuario.',
};

const comparisons = (await getCollection('comparisons'))
  .filter((c) => !c.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <Breadcrumb items={[{ label: 'Inicio', href: '/' }, { label: 'Comparativas' }]} />

    <header class="mb-10">
      <p class="text-sm uppercase tracking-wider text-lime-600 dark:text-lime-400 font-semibold">Comparativas</p>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mt-2">
        Comparativas de {{PRODUCTO_PLURAL}}
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-400 max-w-3xl">
        Ponemos los modelos más populares frente a frente, con tablas claras y veredicto por
        perfil de uso. Diseñadas para decidir en minutos, no para aburrirte con specs
        genéricas. Si no sabes qué modelo mirar, empieza por la comparativa más reciente.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {comparisons.map((c) => (
        <a
          href={`/comparativas/${c.id}`}
          class="group block rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 overflow-hidden hover:-translate-y-1 hover:shadow-lg hover:border-lime-400 transition"
        >
          {c.data.image && (
            <div class="h-48 bg-slate-50 dark:bg-slate-800 flex items-center justify-center overflow-hidden">
              <img src={c.data.image} alt={c.data.title} loading="lazy" class="h-full object-contain transition-transform duration-300 group-hover:scale-105" />
            </div>
          )}
          <div class="p-6">
            <p class="text-xs uppercase tracking-wider text-lime-600 dark:text-lime-400 font-semibold">
              {c.data.category}
            </p>
            <h2 class="font-heading text-xl font-bold mt-2 group-hover:text-lime-600 dark:group-hover:text-lime-400">
              {c.data.title}
            </h2>
            <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">{c.data.excerpt}</p>
            <p class="mt-4 text-sm font-semibold text-lime-700 dark:text-lime-400">Ver comparativa →</p>
          </div>
        </a>
      ))}
    </div>

    {comparisons.length === 0 && (
      <p class="text-slate-600 dark:text-slate-400">Próximamente nuevas comparativas.</p>
    )}
  </section>
</Layout>
