---
import { getCollection, render } from 'astro:content';
import { SITE } from 'astrowind:config';
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/content/Breadcrumb.astro';
import Disclaimer from '~/components/afiliados/Disclaimer.astro';

export const prerender = true;

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const siteUrl = SITE.site;
const siteName = SITE.name;

const canonicalUrl = new URL(`/guias/${entry.id}`, Astro.site ?? siteUrl).toString();

const metadata = {
  title: entry.data.metadata?.title || entry.data.title,
  description: entry.data.metadata?.description || entry.data.excerpt,
  canonical: `/guias/${entry.id}`,
  openGraph: {
    type: 'article',
    images: entry.data.image ? [{ url: entry.data.image, width: 1200, height: 628 }] : undefined,
  },
};

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.excerpt,
  url: canonicalUrl,
  datePublished: entry.data.publishDate.toISOString(),
  ...(entry.data.updateDate ? { dateModified: entry.data.updateDate.toISOString() } : {}),
  inLanguage: 'es-ES',
  author: { '@type': 'Organization', name: siteName, url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: siteName,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
};
---

<Layout metadata={metadata}>
  <article class="mx-auto max-w-3xl px-4 py-12 prose dark:prose-invert prose-lime">
    <Breadcrumb
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Guías', href: '/guias' },
        { label: entry.data.title },
      ]}
    />

    <header class="not-prose mb-8">
      <p class="text-sm uppercase tracking-wider text-lime-600 dark:text-lime-400 font-semibold">
        {entry.data.category}
      </p>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold mt-2 leading-tight">
        {entry.data.title}
      </h1>
      <p class="mt-3 text-lg text-slate-600 dark:text-slate-400">{entry.data.excerpt}</p>
      <div class="mt-4 text-sm text-slate-500">
        Por {entry.data.author} ·{' '}
        <time datetime={entry.data.publishDate.toISOString()}>
          {entry.data.publishDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
    </header>

    <Content />

    <div class="not-prose mt-12">
      <Disclaimer />
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} is:inline />
</Layout>
