---
import '~/assets/styles/tailwind.css';

import { I18N, SITE } from 'astrowind:config';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import GoogleAnalytics from '~/components/common/Analytics.astro';
import Clarity from '~/components/common/Clarity.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import VercelAnalytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import AmazonClickTracker from '~/components/common/AmazonClickTracker.astro';
import CookieBanner from '~/components/common/CookieBanner.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
const { language, textDirection } = I18N;

const siteUrl = SITE.site;

const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.name,
  url: siteUrl,
  logo: `${siteUrl}/favicon.svg`,
  description:
    'Reviews, comparativas y guías de compra de {{PRODUCTO_PLURAL}} disponibles en Amazon España.',
  founder: {
    '@type': 'Person',
    '@id': `${siteUrl}/about#mario-martin`,
    name: '{{AUTOR}}',
    url: `${siteUrl}/about`,
    jobTitle: 'Editor y analista de movilidad urbana',
    knowsAbout: ['{{PRODUCTO_PLURAL}}'],
  },
  sameAs: [],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer support',
    email: '{{EMAIL}}',
    areaServed: 'ES',
    availableLanguage: ['Spanish'],
  },
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  url: siteUrl,
  inLanguage: 'es-ES',
  publisher: { '@type': 'Organization', name: SITE.name },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/reviews?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang={language} dir={textDirection} class="2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <GoogleAnalytics />
    <Clarity />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />

    <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} is:inline />
  </head>

  <body class="antialiased text-default bg-page tracking-tight">
    <slot />

    <BasicScripts />
    <VercelAnalytics />
    <SpeedInsights />
    <AmazonClickTracker />
    <CookieBanner />
  </body>
</html>
