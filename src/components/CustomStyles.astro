---
import '@fontsource-variable/inter';
import '@fontsource-variable/space-grotesk';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Space Grotesk Variable';

    /* Lima eléctrico + grafito */
    --aw-color-primary: rgb(10 10 10); /* grafito botón */
    --aw-color-secondary: rgb(26 26 26);
    --aw-color-accent: rgb(132 204 22); /* lima 500 */
    --aw-color-accent-strong: rgb(101 163 13); /* lima 600 */

    --aw-color-text-heading: rgb(10 10 10);
    --aw-color-text-default: rgb(23 23 23);
    --aw-color-text-muted: rgb(23 23 23 / 70%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(12 14 18);

    ::selection {
      background-color: rgb(190 242 100); /* lima 300 */
      color: rgb(10 10 10);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Space Grotesk Variable';

    --aw-color-primary: rgb(190 242 100); /* en dark el primario pasa a lima para CTA claro */
    --aw-color-secondary: rgb(163 230 53);
    --aw-color-accent: rgb(190 242 100);

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(226 232 240 / 70%);
    --aw-color-bg-page: rgb(12 14 18);

    ::selection {
      background-color: rgb(101 163 13);
      color: rgb(247 254 231);
    }
  }

  /* Tipografía de precios: números tabulares */
  .tabular-nums,
  [data-price] {
    font-variant-numeric: tabular-nums;
  }
</style>
