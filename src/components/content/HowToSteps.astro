---
/**
 * HowToSteps: lista numerada de pasos con schema.org HowTo en JSON-LD.
 *
 * Nota sobre rich results Google: HowTo rich results fueron eliminados en
 * septiembre 2023. El schema sigue siendo útil para:
 *   - AI crawlers (ChatGPT, Claude, Perplexity) que extraen pasos
 *   - Bing que aún soporta el rich result
 *   - Comprensión semántica del contenido por buscadores
 *
 * Uso en MDX:
 *   <HowToSteps
 *     title="Cómo limpiar el prefiltro"
 *     description="Rutina mensual de mantenimiento del prefiltro"
 *     totalTime="PT10M"
 *     steps={[
 *       { name: 'Desenchufar', text: 'Desenchufa el aparato de la red.' },
 *       { name: 'Abrir base', text: 'Gira la base en sentido antihorario.' },
 *     ]}
 *   />
 */

export interface Step {
  name: string;
  text: string;
  image?: string;
  url?: string;
}

export interface Props {
  title: string;
  steps: Step[];
  description?: string;
  totalTime?: string; // ISO 8601 duration, ej. "PT15M" para 15 min
  estimatedCost?: { currency: string; value: number };
  tools?: string[];
  supplies?: string[];
}

const { title, steps, description, totalTime, estimatedCost, tools, supplies } = Astro.props;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: title,
  ...(description ? { description } : {}),
  ...(totalTime ? { totalTime } : {}),
  ...(estimatedCost
    ? {
        estimatedCost: {
          '@type': 'MonetaryAmount',
          currency: estimatedCost.currency,
          value: estimatedCost.value,
        },
      }
    : {}),
  ...(tools && tools.length ? { tool: tools.map((t) => ({ '@type': 'HowToTool', name: t })) } : {}),
  ...(supplies && supplies.length ? { supply: supplies.map((s) => ({ '@type': 'HowToSupply', name: s })) } : {}),
  step: steps.map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: step.name,
    text: step.text,
    ...(step.image ? { image: step.image } : {}),
    ...(step.url ? { url: step.url } : {}),
  })),
};
---

<section class="not-prose my-10 rounded-xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-900 p-6 sm:p-8">
  <header class="mb-6">
    <h3 class="font-heading text-xl sm:text-2xl font-bold text-slate-900 dark:text-slate-100">
      {title}
    </h3>
    {description && (
      <p class="mt-2 text-slate-600 dark:text-slate-400">{description}</p>
    )}
    {totalTime && (
      <p class="mt-3 text-sm text-cyan-700 dark:text-cyan-400 font-semibold">
        Tiempo total: {totalTime.replace(/^PT/, '').replace('M', ' min').replace('H', ' h ')}
      </p>
    )}
  </header>

  <ol class="space-y-5">
    {steps.map((step, i) => (
      <li class="flex items-start gap-4">
        <span class="shrink-0 flex items-center justify-center w-9 h-9 rounded-full bg-cyan-500 text-white font-heading font-bold text-sm tabular-nums">
          {i + 1}
        </span>
        <div class="flex-1 min-w-0 pt-1">
          <p class="font-heading font-bold text-base text-slate-900 dark:text-slate-100">
            {step.name}
          </p>
          <p class="mt-1 text-slate-700 dark:text-slate-300 leading-relaxed">
            {step.text}
          </p>
          {step.image && (
            <img
              src={step.image}
              alt={step.name}
              loading="lazy"
              class="mt-3 rounded-lg border border-slate-200 dark:border-slate-700 max-w-sm h-auto"
            />
          )}
        </div>
      </li>
    ))}
  </ol>
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
