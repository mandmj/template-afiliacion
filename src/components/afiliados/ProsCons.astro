---
export interface Props {
  pros: string[];
  cons: string[];
}
const { pros, cons } = Astro.props;
---

<div class="grid gap-4 md:grid-cols-2 my-6">
  <div class="rounded-lg border border-emerald-300 bg-emerald-50 dark:bg-emerald-950/30 p-4">
    <h4 class="font-bold text-emerald-800 dark:text-emerald-200 mb-2">Ventajas</h4>
    <ul class="space-y-1 text-sm">
      {pros.map((p) => <li>✅ {p}</li>)}
    </ul>
  </div>
  <div class="rounded-lg border border-rose-300 bg-rose-50 dark:bg-rose-950/30 p-4">
    <h4 class="font-bold text-rose-800 dark:text-rose-200 mb-2">Inconvenientes</h4>
    <ul class="space-y-1 text-sm">
      {cons.map((c) => <li>❌ {c}</li>)}
    </ul>
  </div>
</div>
