---
export interface Props {
  score: number; // 0-10
  label?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { score, label = 'Nota', size = 'md' } = Astro.props;
const clamped = Math.max(0, Math.min(10, score));

// Color según nota: rojo <5, ámbar <7, lima >=7
let ring = 'ring-rose-500 bg-rose-50 dark:bg-rose-950/40 text-rose-700 dark:text-rose-200';
if (clamped >= 5) ring = 'ring-amber-500 bg-amber-50 dark:bg-amber-950/40 text-amber-700 dark:text-amber-200';
if (clamped >= 7) ring = 'ring-lime-500 bg-lime-50 dark:bg-lime-950/40 text-lime-700 dark:text-lime-200';
if (clamped >= 9) ring = 'ring-lime-600 bg-lime-100 dark:bg-lime-900/50 text-lime-800 dark:text-lime-100';

const sizes = {
  sm: 'w-14 h-14 text-lg',
  md: 'w-20 h-20 text-2xl',
  lg: 'w-28 h-28 text-4xl',
};
---

<div
  class={`inline-flex flex-col items-center justify-center rounded-full ring-4 font-heading font-bold tabular-nums ${ring} ${sizes[size]}`}
  aria-label={`${label}: ${clamped} sobre 10`}
>
  <span class="leading-none">{clamped.toFixed(1)}</span>
  <span class="text-[10px] font-semibold uppercase tracking-wider opacity-70">/10</span>
</div>
